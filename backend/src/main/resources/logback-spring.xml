<?xml version="1.0" encoding="UTF-8"?>
<!--
  日志配置（Spring Boot 自动加载 logback-spring.xml）。

  目标：
  - 持久化：日志写入 backend/logs/music-share.log；
  - 滚动：按天 + 单文件超 100MB 切分（SizeAndTimeBasedRollingPolicy）；
  - 压缩：归档文件自动 gzip（文件名 .gz 后缀触发）；
  - 保留 1 个月：maxHistory=30（保留 30 天归档，更早自动删），totalSizeCap=3GB 兜底防爆盘；
  - 双输出：控制台（开发期可见）+ 文件（持久化）。

  复用 Spring Boot 内置 base 定义的颜色/格式常量与默认级别。
-->
<configuration>

    <!-- 引入 Spring Boot 默认的转换器、控制台格式等基础定义 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 日志根目录：相对启动工作目录（backend/），即 backend/logs/ -->
    <property name="LOG_DIR" value="logs"/>
    <property name="LOG_FILE" value="${LOG_DIR}/music-share.log"/>

    <!-- 文件日志格式：时间 线程 级别 logger - 消息 -->
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ============ 控制台输出（开发期可见，带颜色） ============ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============ 文件输出（持久化 + 滚动 + 压缩 + 保留期） ============ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前活动日志文件 -->
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 按时间(天) + 大小滚动；归档 .gz 自动压缩 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 归档命名：music-share.2026-06-13.0.log.gz（.gz 触发压缩） -->
            <fileNamePattern>${LOG_DIR}/music-share.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <!-- 单个文件大小上限，超过当天再切下一个序号 -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留 30 天归档（约 1 个月），更早的自动删除 -->
            <maxHistory>30</maxHistory>
            <!-- 归档总量上限，防止异常爆量占满磁盘（兜底） -->
            <totalSizeCap>3GB</totalSizeCap>
            <!-- 应用启动时即清理超期归档（而非等到首次滚动） -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <!-- ============ 根 logger：INFO 级别，控制台 + 文件双写 ============ -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
