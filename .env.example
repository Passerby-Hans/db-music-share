# 发行版 compose 可调参数。compose 已内置默认值(${VAR:-default})，开箱即用；
# 要覆盖就 `cp .env.example .env` 后改值(docker compose 自动读取 .env)。
PUBLIC_HOST=localhost      # 改为 LAN IP / 域名即可对外访问
APP_PORT=8080              # nginx 应用端口
MINIO_PORT=9000            # nginx 直透 MinIO 端口
POSTGRES_PASSWORD=music123
MINIO_ROOT_PASSWORD=music123456
